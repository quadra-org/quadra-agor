{
  "name": "@agor-live/client",
  "version": "0.16.0",
  "description": "TypeScript client for connecting to the Agor daemon",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node scripts/patch-dts.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@feathersjs/authentication-client": "^5.0.41",
    "@feathersjs/feathers": "^5.0.41",
    "@feathersjs/rest-client": "^5.0.41",
    "@feathersjs/socketio-client": "^5.0.41",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@agor/core": "workspace:*",
    "@types/node": "^22.10.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "agor",
    "client",
    "ai",
    "agents",
    "orchestration"
  ],
  "author": "Maxime Beauchemin <maximebeauchemin@gmail.com>",
  "license": "BUSL-1.1",
  "homepage": "https://agor.live",
  "repository": {
    "type": "git",
    "url": "https://github.com/preset-io/agor.git",
    "directory": "packages/client"
  },
  "bugs": {
    "url": "https://github.com/preset-io/agor/issues"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
